import { useState, useEffect } from 'react';
import { useLocation } from 'react-router-dom'; 
import { Dashboard } from '../layout/Dashboard';
import { GameOverModal } from './GameOverModal';
import { TheoryModal } from './TheoryModal';
import { api } from '../../api/client';
import { GameState } from '../../types/game';

export const GameSession = () => {
  const [gameState, setGameState] = useState<GameState | null>(null);
  const [showTheory, setShowTheory] = useState(true); // Always show theory first
  
  const location = useLocation();
  const currentLevelId = location.state?.scenarioId || 'linux_basics_1';

  // INITIALIZE
  useEffect(() => {
    const init = async () => {
      const state = await api.startGame('attacker', 'medium', currentLevelId);
      setGameState(state);
    };
    init();
  }, [currentLevelId]);

  const handleAction = async (input: string) => {
    if (!gameState) return;
    
    // Check if we need to switch stages
    if (input === 'NEXT_STAGE') {
        const newState = await api.sendAction('START_EXAM');
        setGameState(newState);
        return;
    }

    const newState = await api.sendAction(input);
    setGameState(newState);
  };

  const closeTheory = () => {
    setShowTheory(false);
    // Tell backend to start training
    api.sendAction('START_TRAINING').then(setGameState);
  };

  if (!gameState) return <div className="bg-slate-950 min-h-screen text-emerald-500 p-10 font-mono">Loading Course...</div>;

  return (
    <>
      {/* STAGE 1: THEORY MODAL (Forced) */}
      {showTheory && gameState.theory && (
        <TheoryModal content={gameState.theory} onClose={closeTheory} />
      )}

      {/* DASHBOARD HANDLES STAGE 2 (Training) & 3 (Exam) */}
      <Dashboard 
        state={gameState} 
        onAction={handleAction} 
        // In Exam stage, force manual input
        inputMode={gameState.stage === 'exam' ? 'manual' : 'button'} 
      />
      
      {gameState.isGameOver && (
        <GameOverModal 
          result={gameState.gameResult} 
          score={100}
          onRestart={() => window.location.reload()}
          currentLevelId={currentLevelId} 
        />
      )}
    </>
  );
};